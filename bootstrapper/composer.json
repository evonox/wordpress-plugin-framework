{
    "autoload": {
        "psr-4": {
            "__PLUGIN__\\": "src/",
            "Tests\\": "tests/",
            "WPTests\\": "tests-wp/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "3.13.5",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpunit/phpunit": "^13.0",
        "phpunit/php-code-coverage": "^13.0",
        "wp-coding-standards/wpcs": "3.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require": {
        "twig/twig": "^3.23"
    }
}
